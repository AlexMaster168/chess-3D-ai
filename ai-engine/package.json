{
  "name": "@chess-ai/engine",
  "version": "0.1.0",
  "description": "TypeScript chess AI engine: minimax + alpha-beta + quiescence + opening book, selectable difficulty, Web Worker compatible.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "chess",
    "ai",
    "minimax",
    "alpha-beta",
    "engine",
    "worker"
  ],
  "license": "MIT",
  "dependencies": {
    "chess.js": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
